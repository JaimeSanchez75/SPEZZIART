RewriteEngine On
RewriteBase /App/

# Si el archivo existe (como App/login.js), sírvelo directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Si es una carpeta de pages, al index.php (evita el Index of)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^pages/.*$ index.php [L,QSA]

# El resto de rutas lógicas (auth/login, etc.) al index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]